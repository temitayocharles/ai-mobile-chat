# -----------------------------
# OS / Filesystem
# -----------------------------
.DS_Store
.AppleDouble
.LSOverride
Icon?
._*

# -----------------------------
# Python bytecode / caches
# -----------------------------
__pycache__/
*.py[cod]
*$py.class

# Python tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pyre/
.hypothesis/
.tox/
.nox/
.coverage
.coverage.*
htmlcov/

# -----------------------------
# Virtual environments
# -----------------------------
.venv/
venv/
env/
ENV/

# -----------------------------
# Environment / secrets
# -----------------------------
.env
.env.*
*.local

# Allow example env templates
!.env.example

# -----------------------------
# Build / packaging artifacts
# -----------------------------
build/
dist/
site/
.eggs/
*.egg
*.egg-info/
pip-wheel-metadata/

# -----------------------------
# Logs / PIDs / runtime temp files
# -----------------------------
*.log
*.out
*.err
*.pid
*.pid.lock
tmp/
temp/

# -----------------------------
# SQLite / local app state
# -----------------------------
*.db
*.db-shm
*.db-wal

# Entire runtime data directory
data/

# Allow tracked placeholder if you want the folder to exist in Git
!data/.gitkeep

# -----------------------------
# Editors / IDEs
# -----------------------------
.vscode/
.idea/
*.swp
*.swo

# -----------------------------
# Jupyter
# -----------------------------
.ipynb_checkpoints/

# -----------------------------
# Optional: local developer docs/output
# -----------------------------
*.sqlite3
PERSONAL.code-workspace
source
